---
import SkipNavContent from '@components/a11y/skip-nav-content.astro'
import Link from '@components/link.astro'
import Seo from '@components/seo.astro'
import Spacer from '@components/spacer.astro'
import Layout from '@layouts/layout.astro'
import { getTags } from '@utils'
import { getCollection } from 'astro:content'

const entries = await getCollection('blog')

const tags = getTags(entries)

const tagsDescription = 'Browse all topics covered on the SEWWA blog — SEO, AI search, JSON-LD schema, developer tools, and more.'
---

<Layout>
	<Seo slot="seo" title="Tags" description={tagsDescription} />
	<SkipNavContent searchIndex={true}>
		<span class="sr-only" data-pagefind-filter="section">Tags</span>
		<h2 class="font-medium text-xl md:text-2xl lg:text-3xl text-highlight" data-pagefind-meta="title">
			All tags
		</h2>
		<Spacer axis="vertical" size={12} />
		<div class="flex gap-6 flex-col">
			{
				tags.map(({ tag, slug, count }) => (
					<Link variant="highlight" href={`${import.meta.env.BASE_URL}tags/${slug}/`}>
						{tag} ({count})
					</Link>
				))
			}
		</div>
	</SkipNavContent>
</Layout>
