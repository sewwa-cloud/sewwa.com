---
import Layout from '@layouts/layout.astro'
import Seo from '@components/seo.astro'
import SkipNavContent from '@components/a11y/skip-nav-content.astro'
import { Content } from '@assets/about.mdx'
import Prose from '@components/prose.astro'
import Spacer from '@components/spacer.astro'
import { CONTACT_EMAIL, SITE } from '@constants'
import { sewwaOrganizationProperties } from '@data/organization-json-ld'

const title = 'About'
const description = `Sewwa offers free SEO tools and guides—JSON-LD schema, structured data, and expert tips. Contact us at ${CONTACT_EMAIL}.`
---

<Layout>
	<Seo
		slot="seo"
		title={title}
		description={description}
		image={SITE.defaultOgImage}
		ogType="website"
		schema={{
			'@context': 'https://schema.org',
			...sewwaOrganizationProperties({ email: CONTACT_EMAIL }),
		}}
	/>
	<SkipNavContent searchIndex={true}>
		<Prose>
			<p class="sr-only">
				<span data-pagefind-filter="section">About</span>
			</p>
			<h1 data-pagefind-meta="title">{title}</h1>
			<Spacer axis="vertical" size={8} />
			<Content />
		</Prose>
	</SkipNavContent>
</Layout>
