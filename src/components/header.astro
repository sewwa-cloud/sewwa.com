---
import { Image } from 'astro:assets'
import { HEADER, SITE } from '@constants'
import Link from './link.astro'
import Spacer from './spacer.astro'
import Search from './search.astro'
import logoImage from '../assets/logo/sewwa.png'

const base = import.meta.env.BASE_URL
const { pathname } = Astro.url

function navHref(url: string): string {
	return `${base}${url.replace(/^\//, '')}`
}

function isNavActive(url: string): boolean {
	const p = pathname.endsWith('/') ? pathname : `${pathname}/`
	return p === url
}
---

<header class="container">
	<Spacer axis="vertical" size={8} />
	<div class="flex flex-row justify-between items-center">
		<div>
			<a href={base} aria-label={`${SITE.title} - Back to home`}>
				<Image src={logoImage} alt={SITE.title} class="h-8 md:h-10 lg:h-12 size-auto" height={60} />
			</a>
		</div>
		<Search />
	</div>
	<Spacer axis="vertical" size={6} />
	<div class="flex flex-row flex-wrap justify-between items-center gap-y-3 border-b border-border pb-4 text-lg md:text-xl">
		<nav aria-label="Primary navigation" class="flex flex-wrap gap-4">
			{
				HEADER.internal.map((link) => (
					<Link
						href={navHref(link.url)}
						class={isNavActive(link.url) ? 'active' : ''}
						aria-current={isNavActive(link.url) ? 'page' : undefined}
					>
						{link.title}
					</Link>
				))
			}
		</nav>
		<div class="flex flex-wrap gap-4">
			{
				HEADER.external.map((link) => (
					<Link href={link.url} {...link.props}>
						{link.title}
					</Link>
				))
			}
		</div>
	</div>
	<Spacer axis="vertical" size={16} />
</header>
